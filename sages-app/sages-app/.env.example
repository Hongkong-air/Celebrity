# 环境变量配置模板
# 复制为 .env 后填入实际值

# === 应用配置 ===
APP_NAME=SagesApp
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://sages:sages123@localhost:5432/sages_db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Qdrant 向量数据库 ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sages

# === Embedding 服务 ===
EMBEDDING_SERVICE_URL=http://localhost:8001

# === LLM 服务 (vLLM) ===
LLM_BASE_URL=http://localhost:8002/v1
LLM_MODEL_NAME=base-model
LLM_API_KEY=not-needed

# === JWT ===
JWT_SECRET_KEY=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === 限流 ===
RATE_LIMIT_PER_MINUTE=30
